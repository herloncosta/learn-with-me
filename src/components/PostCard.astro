---
export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
}

const { title, description, pubDate, slug } = Astro.props;
---

<article class="group border-b border-border py-6 first:pt-0">
  <a
    href={`/blog/${slug}`}
    class="block no-underline hover:no-underline text-inherit transition-all duration-200 group-hover:pl-3"
  >
    <time
      class="block text-xs text-ink-dim mb-1"
      datetime={pubDate.toISOString()}
    >
      {pubDate.toLocaleDateString("pt-BR", {
        timeZone: "UTC",
        day: "numeric",
        month: "short",
        year: "numeric",
      })}
    </time>
    <h2
      class="text-lg font-semibold leading-tight mb-1.5 text-ink transition-colors duration-200 group-hover:text-primary"
    >
      {title}
    </h2>
    <p class="text-xs text-ink-muted leading-relaxed">
      {description}
    </p>
  </a>
</article>
