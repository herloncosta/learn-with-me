---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const SITE = Astro.site ?? new URL("https://lwm-blog.netlify.app");

const author = {
  name: "Herlon Costa",
  bio: "29 anos, analista de sistemas, desenvolvedor web e entusiasta do ecossistema Linux.",
  url: "https://herloncosta.netlify.app",
};

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postUrl = new URL(`blog/${post.id}/`, SITE).href;
const shareTitle = `${post.data.title} — learn-with-me`;
const encodedUrl = encodeURIComponent(postUrl);
const waShare = `https://wa.me/?text=${encodeURIComponent(shareTitle)}%0A${encodedUrl}`;
const liShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<BaseLayout
  title={`${post.data.title} — learn-with-me`}
  description={post.data.description}
>
  <article>
    <header class="mb-10 pb-6 border-b border-border">
      <h1 class="text-[clamp(1.5rem,4vw,2rem)] font-bold leading-tight mb-3 text-ink">
        {post.data.title}
      </h1>
      <div class="text-xs text-ink-dim flex flex-wrap gap-1">
        <span class="flex items-center gap-1">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <a href={author.url} class="text-ink-dim hover:text-primary no-underline hover:no-underline">
            {author.name}
          </a>
        </span>
        <span class="text-border">·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("pt-BR", {
            timeZone: "UTC",
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
        {post.data.updatedDate && (
          <>
            <span class="text-border">·</span>
            <span>
              Updated{" "}
              <time datetime={post.data.updatedDate.toISOString()}>
                {post.data.updatedDate.toLocaleDateString("pt-BR", {
                  timeZone: "UTC",
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                })}
              </time>
            </span>
          </>
        )}
      </div>
    </header>
    <div class="post-content text-sm">
      <Content />
    </div>
    <footer class="mt-12 pt-6 border-t border-border">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3 text-xs text-ink-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <div>
            <a href={author.url} class="font-medium text-ink hover:text-primary no-underline hover:no-underline">
              {author.name}
            </a>
            <p class="text-ink-dim mt-0.5 max-w-sm">{author.bio}</p>
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <span class="text-xs text-ink-dim">Compartilhar:</span>
          <a
            href={waShare}
            target="_blank"
            rel="noopener noreferrer"
            class="size-8 flex items-center justify-center border border-border text-ink-dim hover:text-primary hover:border-primary transition-colors duration-150"
            aria-label="Compartilhar no WhatsApp"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a
            href={liShare}
            target="_blank"
            rel="noopener noreferrer"
            class="size-8 flex items-center justify-center border border-border text-ink-dim hover:text-primary hover:border-primary transition-colors duration-150"
            aria-label="Compartilhar no LinkedIn"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>
